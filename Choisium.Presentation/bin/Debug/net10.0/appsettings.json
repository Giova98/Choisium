{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ChoisiumDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "SecretKey": "REEMPLAZAR-CON-USER-SECRETS-EN-DESARROLLO",
    "Issuer": "Choisium",
    "Audience": "ChoisiumClient",
    "ExpirationHours": 1
  },
    "PollySettings": {
    "RetryCount": 3,
    "RetryAttemptInSeconds": 1,
    "HandledEventsAllowedBeforeBreaking": 5,
    "DurationOfBreakInSeconds": 30
  },
  "AllowedHosts": "*"
}