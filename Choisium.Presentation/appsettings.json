{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ChoisiumDb;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
